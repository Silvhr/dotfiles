#!/bin/sh

current_default=$(xdg-settings get default-web-browser)

if [ "$current_default" = "firefox-nightly.desktop" ]; then
    xdg-settings set default-web-browser google-chrome.desktop
    notify-send "Default browser set to Google Chrome"
else
    xdg-settings set default-web-browser firefox-nightly.desktop
    notify-send "Default browser set to Firefox"
fi

